# ── AgentOrc OpenAI demo harness ──────────────────────────────────────────
# One key drives: embeddings, chat/compress, vision (image text), rerank.
# Upload fixtures/sample.pdf and fixtures/sample.png (or .jpg) before running.

OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Models (all OpenAI)
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4.1-mini
VISION_MODEL=gpt-4o-mini
RERANK_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# Always use OpenAI vision + OpenAI rerank in this demo
ENABLE_VISION=true
ENABLE_RERANK=true

# Dual backends
BACKENDS=sqlite,postgres
DATABASE_PATH=./data/memory-sqlite.db
ORGANIZATION=openai-demo

# PostgreSQL — required when BACKENDS includes postgres
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/agentorc
REQUIRE_POSTGRES=true

FIXTURES_DIR=./fixtures
