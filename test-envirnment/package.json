{
  "name": "agentorc-test-environment",
  "version": "2.1.0",
  "private": true,
  "description": "Dual-backend (SQLite + PostgreSQL) full API harness for AgentOrc v0.2",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
